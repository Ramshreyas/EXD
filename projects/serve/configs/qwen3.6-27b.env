# Qwen3.6 27B - initial GB10 recipe
# Source: huggingface.co/Qwen/Qwen3.6-27B
# Multimodal, 128k context, Qwen3 reasoning parser, tool calls, MTP ON.
MODEL=Qwen/Qwen3.6-27B
SERVED_NAME=Qwen/Qwen3.6-27B
IMAGE=vllm/vllm-openai:v0.20.0
GPU_MEM_UTIL=0.80
# vllm/vllm-openai entrypoint already runs `vllm serve`.
CMD_PREFIX=()

EXTRA_DOCKER_ARGS=()

EXTRA_VLLM_ARGS=(
  --dtype bfloat16
  --tensor-parallel-size 1
  --pipeline-parallel-size 1
  --data-parallel-size 1
  --max-model-len 131072
  --reasoning-parser qwen3
  --enable-auto-tool-choice
  --tool-call-parser qwen3_coder
  --speculative-config '{"method":"qwen3_next_mtp","num_speculative_tokens":2}'
  --enable-prefix-caching
)
